NEXT_PUBLIC_SUPABASE_URL=https://supabase.suaempresa.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

NEXT_PUBLIC_CHATWOOT_URL=https://chat.suaempresa.com
NEXT_PUBLIC_CHATWOOT_ACCOUNT_ID=1

SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=sua-evolution-api-key-aqui
EVOLUTION_WEBHOOK_TOKEN=um-token-seguro-para-webhook

# MinIO onde a Evolution guarda a mídia — usado para re-assinar/servir objetos
# cuja URL pré-assinada (validade máx. 7 dias no S3) já expirou.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=evolution-storage
MINIO_ACCESS_KEY=minio-root-user
MINIO_SECRET_KEY=minio-root-password

AI_AGENT_ENABLED=false
